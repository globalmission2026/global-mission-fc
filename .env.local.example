# ── Supabase ──────────────────────────────────────────────────────────────────
# 1. Go to https://supabase.com → New Project
# 2. Settings → API → copy the values below
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# 1. Go to https://resend.com → New API Key
# 2. Paste key below (used by /api/contact route)
RESEND_API_KEY=re_YOUR_RESEND_KEY

# ── Cloudinary (image CDN - 25GB free) ────────────────────────────────────────
# 1. Go to https://cloudinary.com → Sign up (free: 25GB storage, 25GB bandwidth)
# 2. Dashboard → copy Cloud name, API Key, API Secret
# 3. Settings → Upload → Enable unsigned uploads, create an upload preset
#    → Copy the preset name (used for client-side uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Only needed for client-side (unsigned) uploads:
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=gmfc_unsigned

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
