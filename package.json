    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.6",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0",
    "wrangler": "^4.113.0"
